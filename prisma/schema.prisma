generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Board {
  id        String   @id @default(cuid())
  name      String
  data      String   // JSON string of objects and lines
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
